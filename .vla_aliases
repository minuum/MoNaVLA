# MoNaVLA (Mobile Navigation VLA) Environment Setup
# 
# 이 파일은 MoNaVLA 시스템의 양쪽 서버에서 사용됩니다:
# - Jetson (fevers): 로봇 서버 - 이미지 캡쳐, 주행 제어
# - Billy (A5000): 모델 서버 - VLA 추론
#
# Source this file in your ~/.zshrc or ~/.bashrc:
# echo 'source /home/soda/MoNaVLA/.vla_aliases' >> ~/.zshrc
#
# ========================================
# 서버 역할 감지
# ========================================

# 현재 서버가 어느 역할인지 자동 감지
if [ "$(hostname)" = "fevers" ]; then
    export VLA_SERVER_ROLE="jetson"
    export VLA_SERVER_NAME="MoNaVLA Jetson Robot"
elif [ "$(hostname)" = "billy" ]; then
    export VLA_SERVER_ROLE="model"
    export VLA_SERVER_NAME="MoNaVLA Billy Server"
else
    export VLA_SERVER_ROLE="unknown"
    export VLA_SERVER_NAME="MoNaVLA Unknown Server"
fi

# ========================================
# 공통 환경 변수
# ========================================

export VLA_PROJECT_DIR="/home/soda/MoNaVLA"
export MONAVLA_ROOT="/home/soda/MoNaVLA"
export VLA_ROS_WS="${VLA_ROS_WS:-/home/soda/MoNaVLA/ROS_action}"

# Tailscale VPN 주소
export JETSON_TAILSCALE_IP="${JETSON_TAILSCALE_IP:-100.85.118.58}"
export BILLY_TAILSCALE_IP="${BILLY_TAILSCALE_IP:-100.86.152.29}"  # Billy 서버의 Tailscale IP
export VLA_SYNC_HOST="${VLA_SYNC_HOST:-$BILLY_TAILSCALE_IP}"
export VLA_SYNC_USER="${VLA_SYNC_USER:-soda}"
export VLA_SYNC_SSH_PORT="${VLA_SYNC_SSH_PORT:-22}"
export VLA_SYNC_ROOT="${VLA_SYNC_ROOT:-$VLA_PROJECT_DIR}"

# ========================================
# Jetson 서버 전용 설정
# ========================================

if [ "$VLA_SERVER_ROLE" = "jetson" ]; then
    # proxy_inference_server가 Jetson 로컬에서 실행됨 (포트 8001)
    export VLA_API_SERVER="${VLA_API_SERVER:-http://localhost:8001}"
    export VLA_API_KEY="${VLA_API_KEY:-vla_devel_key_2026}"
    export VLA_MODEL="${VLA_MODEL:-exp49}"

    # ROS2 환경
    export ROS_DOMAIN_ID=42
    export RMW_IMPLEMENTATION="${RMW_IMPLEMENTATION:-rmw_fastrtps_cpp}"
fi

# ========================================
# Model 서버 전용 설정
# ========================================

if [ "$VLA_SERVER_ROLE" = "model" ]; then
    # API 서버는 로컬에서 실행
    export VLA_API_SERVER="${VLA_API_SERVER:-http://localhost:8000}"
    export VLA_API_KEY="${VLA_API_KEY:-generate-on-first-run}"
fi

# ========================================
# 서버별 환경 설정 함수
# ========================================

# Jetson 환경 설정 (ROS2 + 로봇 제어)
unalias vla-jetson-env 2>/dev/null || true
vla-jetson-env() {
    if [ "$VLA_SERVER_ROLE" != "jetson" ]; then
        echo "⚠️  경고: 현재 서버는 Jetson이 아닙니다 (현재: $VLA_SERVER_NAME)"
        return 1
    fi
    
    echo "🤖 Jetson Robot Server 환경 설정 중..."
    
    # ROS2 환경 설정
    cd /home/soda/MoNaVLA/ROS_action/install
    source /opt/ros/humble/setup.bash
    source local_setup.bash
    cd - > /dev/null
    
    echo "✓ ROS2 환경 설정 완료"
    echo "✓ Robot Server 준비 완료"
    echo ""
    echo "환경 정보:"
    echo "  서버 역할: Jetson Robot Server"
    echo "  모델 서버: $VLA_API_SERVER"
    echo "  ROS_DOMAIN_ID: $ROS_DOMAIN_ID"
}

# Model 서버 환경 설정 (추론 서버)
unalias vla-model-env 2>/dev/null || true
vla-model-env() {
    if [ "$VLA_SERVER_ROLE" != "model" ]; then
        echo "⚠️  경고: 현재 서버는 Model 서버가 아닙니다 (현재: $VLA_SERVER_NAME)"
        return 1
    fi
    
    echo "🧠 Model Inference Server 환경 설정 중..."
    
    # Python 가상환경 활성화 (필요시)
    # source /home/billy/venv/bin/activate
    
    echo "✓ Model Server 환경 설정 완료"
    echo ""
    echo "환경 정보:"
    echo "  서버 역할: Billy Model Server"
    echo "  API 서버: $VLA_API_SERVER"
    echo "  GPU: NVIDIA RTX A5000"
}

# 환경 변수 확인
unalias vla-env 2>/dev/null || true
vla-env() {
    echo "=========================================="
    echo "MoNaVLA Environment Variables"
    echo "=========================================="
    echo "서버 정보:"
    echo "  Hostname       = $(hostname)"
    echo "  Role           = $VLA_SERVER_ROLE"
    echo "  Server Name    = $VLA_SERVER_NAME"
    echo ""
    echo "프로젝트:"
    echo "  VLA_PROJECT_DIR = $VLA_PROJECT_DIR"
    echo ""
    echo "네트워크:"
    echo "  Jetson IP      = $JETSON_TAILSCALE_IP"
    echo "  Billy IP       = $BILLY_TAILSCALE_IP"
    echo "  API Server     = $VLA_API_SERVER"
    echo "  API Key        = ${VLA_API_KEY:0:20}..."
    echo ""
    if [ "$VLA_SERVER_ROLE" = "jetson" ]; then
        echo "ROS2:"
        echo "  ROS_DOMAIN_ID  = $ROS_DOMAIN_ID"
    fi
}

# ========================================
# API 서버 관리 (Model 서버 전용)
# ========================================

# 서버 시작
alias vla-start="$VLA_PROJECT_DIR/scripts/manage_api_server.sh start"

# 서버 중지
alias vla-stop="$VLA_PROJECT_DIR/scripts/manage_api_server.sh stop"

# 서버 재시작
alias vla-restart="$VLA_PROJECT_DIR/scripts/manage_api_server.sh restart"

# 서버 상태
alias vla-status="$VLA_PROJECT_DIR/scripts/manage_api_server.sh status"

# 서버 로그
alias vla-logs="$VLA_PROJECT_DIR/scripts/manage_api_server.sh logs"

# ========================================
# API 테스트 (양쪽 서버 공통)
# ========================================

# 전체 테스트
alias vla-test="$VLA_PROJECT_DIR/scripts/test_api_server.sh all"

# Health check만
alias vla-health="$VLA_PROJECT_DIR/scripts/test_api_server.sh health"

# Test endpoint만
alias vla-test-endpoint="$VLA_PROJECT_DIR/scripts/test_api_server.sh test"

# Predict endpoint만 (모델 로딩 필요)
alias vla-predict="$VLA_PROJECT_DIR/scripts/test_api_server.sh predict"

# ========================================
# 빠른 명령어
# ========================================

# Health check (curl 직접 호출)
alias vla-curl-health='curl -s $VLA_API_SERVER/health | python3 -m json.tool'

# Test endpoint (curl 직접 호출)
alias vla-curl-test='curl -s -H "X-API-Key: $VLA_API_KEY" $VLA_API_SERVER/test | python3 -m json.tool'

# 프로세스 확인
alias vla-ps='ps aux | grep -E "(api_server|PID)" | grep -v grep'

# 프로젝트 디렉토리로 이동
alias vla-cd='cd $VLA_PROJECT_DIR'

# GPU 상태
if [ "$VLA_SERVER_ROLE" = "jetson" ]; then
    alias vla-gpu='tegrastats'
elif [ "$VLA_SERVER_ROLE" = "model" ]; then
    alias vla-gpu='nvidia-smi'
fi

# ========================================
# 네트워크 테스트
# ========================================

# Tailscale 연결 확인
unalias vla-network-check 2>/dev/null || true
vla-network-check() {
    echo "=========================================="
    echo "MoNaVLA Network Connection Check"
    echo "=========================================="
    echo ""
    
    if [ "$VLA_SERVER_ROLE" = "jetson" ]; then
        echo "Jetson → Billy 연결 테스트:"
        echo -n "  Ping Billy Server... "
        if ping -c 1 -W 2 $BILLY_TAILSCALE_IP > /dev/null 2>&1; then
            echo "✓"
        else
            echo "✗"
        fi
        
        echo -n "  API Server Health... "
        if curl -s -m 2 $VLA_API_SERVER/health > /dev/null 2>&1; then
            echo "✓"
        else
            echo "✗"
        fi
        
    elif [ "$VLA_SERVER_ROLE" = "model" ]; then
        echo "Billy → Jetson 연결 테스트:"
        echo -n "  Ping Jetson Server... "
        if ping -c 1 -W 2 $JETSON_TAILSCALE_IP > /dev/null 2>&1; then
            echo "✓"
        else
            echo "✗"
        fi
    fi
    
    echo ""
    echo "Tailscale 상태:"
    tailscale status | head -5
}

# ========================================
# 도움말
# ========================================

unalias vla-help 2>/dev/null || true
vla-help() {
    echo "=========================================="
    echo "MoNaVLA Commands - $VLA_SERVER_NAME"
    echo "=========================================="
    echo ""
    echo "환경 설정:"
    
    if [ "$VLA_SERVER_ROLE" = "jetson" ]; then
        echo "  mona-jetson-env    - Jetson 환경 설정 (ROS2) [alias: vla-jetson-env]"
        echo ""
        echo "ROS2 관련:"
        echo "  mona-collect       - 데이터 수집 시작 [alias: vla-collect]"
        echo "  mona-camera        - 카메라 토픽 발행 [alias: vla-camera]"
        echo "  robot-move         - 로봇 이동 제어"
        echo "  mona-system        - MoNaVLA 시스템 시작 [alias: vla-system]"
    elif [ "$VLA_SERVER_ROLE" = "model" ]; then
        echo "  mona-model-env     - Model 서버 환경 설정 [alias: vla-model-env]"
        echo ""
        echo "API 서버 관리:"
        echo "  vla-server         - API 서버 시작/관리"
        echo "  mona-start         - API 서버 시작 [alias: vla-start]"
        echo "  mona-stop          - API 서버 중지 [alias: vla-stop]"
        echo "  mona-restart       - API 서버 재시작 [alias: vla-restart]"
        echo "  mona-status        - API 서버 상태 [alias: vla-status]"
        echo "  mona-logs          - API 서버 로그 [alias: vla-logs]"
    fi
    
    echo ""
    echo "API 테스트 (공통):"
    echo "  mona-test          - 전체 API 테스트 [alias: vla-test]"
    echo "  mona-health        - Health check [alias: vla-health]"
    echo ""
    echo "유틸리티:"
    echo "  mona-env           - 환경 변수 확인 [alias: vla-env]"
    echo "  mona-network-check - 네트워크 연결 확인 [alias: vla-network-check]"
    echo "  vla-profile        - 현재 활성 프로파일 해석 결과"
    echo "  vla-models         - 운영 모델 레지스트리 목록"
    echo "  vla-use <profile>  - 현재 셸의 활성 프로파일 변경"
    echo "  vla-doctor         - 프로파일/ROS/API 진단"
    echo "  vla-sync-models    - 활성 profile의 ckpt/config를 원격 서버로 rsync"
    echo "  vla-ps             - 프로세스 확인"
    echo "  mona-cd            - 프로젝트로 이동 [alias: vla-cd]"
    echo "  mona-gpu           - GPU 상태 [alias: vla-gpu]"
    echo "  mona-help          - 이 도움말 [alias: vla-help]"
    echo "=========================================="
}

# ========================================
# MoNaVLA Aliases (Compatibility)
# ========================================

# Base aliases
alias mona-help='vla-help'
alias mona-env='vla-env'
alias mona-cd='vla-cd'
alias mona-network-check='vla-network-check'
alias mona-gpu='vla-gpu'

# Jetson specific
if [ "$VLA_SERVER_ROLE" = "jetson" ]; then
    alias mona-jetson-env='vla-jetson-env'
    alias mona-collect='vla-collect'
    alias mona-camera='vla-camera'
    alias mona-system='vla-system'
    alias mona-inference-server='vla-inference-server'
fi

unalias vla-camera 2>/dev/null || true
vla-camera() {
    source /opt/ros/humble/setup.zsh 2>/dev/null || source /opt/ros/humble/setup.bash 2>/dev/null || true
    if [ -f "$VLA_ROS_WS/install/setup.zsh" ]; then
        source "$VLA_ROS_WS/install/setup.zsh"
    elif [ -f "$VLA_ROS_WS/install/setup.bash" ]; then
        source "$VLA_ROS_WS/install/setup.bash"
    fi
    export ROS_DOMAIN_ID=42
    export RMW_IMPLEMENTATION="${RMW_IMPLEMENTATION:-rmw_fastrtps_cpp}"
    echo "📷 Starting camera service (ROS_DOMAIN_ID=$ROS_DOMAIN_ID)..."
    ros2 run camera_pub usb_camera_service_server
}

unalias vla-inference-server 2>/dev/null || true
vla-inference-server() {
    local model="${VLA_MODEL:-exp49}"
    local port="${VLA_PORT:-8001}"
    echo "🤖 Starting proxy inference server (VLA_MODEL=$model, port=$port)..."
    cd "$VLA_PROJECT_DIR" && nohup env VLA_MODEL="$model" python3 robovlm_nav/serve/proxy_inference_server.py --port "$port" </dev/null >>/tmp/proxy_server.log 2>&1 & disown
    echo "PID $! — logs: tail -f /tmp/proxy_server.log"
}

# Model specific
if [ "$VLA_SERVER_ROLE" = "model" ]; then
    alias mona-model-env='vla-model-env'
    alias mona-start='vla-start'
    alias mona-stop='vla-stop'
    alias mona-restart='vla-restart'
    alias mona-status='vla-status'
    alias mona-logs='vla-logs'
    alias mona-test='vla-test'
    alias mona-health='vla-health'
fi

# ========================================
# 초기 메시지
# ========================================

# echo "✓ VLA aliases loaded - $VLA_SERVER_NAME"
# echo "  Run 'vla-help' for available commands"
# Basket Training Aliases
alias vla-train-log='tail -f /home/billy/25-1kp/vla/logs/train_basket_chunk5_20260129_204053.log'
alias vla-train-stop='pkill -f main.py'

# MoNaVLA Shortcuts
alias vla-analyze='python3 /home/soda/MoNaVLA/scripts/gradio_offline_h5_analyzer.py'

unalias vla-profile 2>/dev/null || true
vla-profile() {
    python3 "$VLA_PROJECT_DIR/scripts/vla_profile.py" profile --profile "${1:-${VLA_PROFILE:-end_to_end_default}}"
}

unalias vla-models 2>/dev/null || true
vla-models() {
    python3 "$VLA_PROJECT_DIR/scripts/vla_profile.py" models "$@"
}

unalias vla-doctor 2>/dev/null || true
vla-doctor() {
    python3 "$VLA_PROJECT_DIR/scripts/vla_profile.py" doctor --profile "${1:-${VLA_PROFILE:-end_to_end_default}}"
}

unalias vla-use 2>/dev/null || true
vla-use() {
    local profile_name="${1:-end_to_end_default}"
    eval "$(python3 "$VLA_PROJECT_DIR/scripts/vla_profile.py" env --profile "$profile_name")"
    echo "✓ Active profile: $VLA_PROFILE ($VLA_MODEL_LABEL)"
}

unalias vla-sync-models 2>/dev/null || true
vla-sync-models() {
    local profile_name="${VLA_PROFILE:-end_to_end_default}"
    local mode=""
    local arg=""
    for arg in "$@"; do
        case "$arg" in
            --dry-run|--print-only)
                mode="$arg"
                ;;
            *)
                profile_name="$arg"
                ;;
        esac
    done

    eval "$(python3 "$VLA_PROJECT_DIR/scripts/vla_profile.py" env --profile "$profile_name")" || return 1

    if [ -z "${VLA_CHECKPOINT_PATH:-}" ] || [ ! -f "$VLA_CHECKPOINT_PATH" ]; then
        echo "Checkpoint not found for profile $VLA_PROFILE: ${VLA_CHECKPOINT_PATH:-N/A}"
        return 1
    fi

    if [ -z "${VLA_CONFIG_PATH:-}" ] || [ ! -f "$VLA_CONFIG_PATH" ]; then
        echo "Config not found for profile $VLA_PROFILE: ${VLA_CONFIG_PATH:-N/A}"
        return 1
    fi

    local remote_base="${VLA_SYNC_USER}@${VLA_SYNC_HOST}:${VLA_SYNC_ROOT}"
    local rsync_args=(-ahz --info=progress2 --relative -e "ssh -p ${VLA_SYNC_SSH_PORT}")
    local ckpt_rel config_rel

    ckpt_rel="${VLA_CHECKPOINT_PATH#$VLA_PROJECT_DIR/}"
    config_rel="${VLA_CONFIG_PATH#$VLA_PROJECT_DIR/}"

    if [ "$ckpt_rel" = "$VLA_CHECKPOINT_PATH" ] || [ "$config_rel" = "$VLA_CONFIG_PATH" ]; then
        echo "Only paths inside $VLA_PROJECT_DIR are supported by vla-sync-models."
        echo "Checkpoint: $VLA_CHECKPOINT_PATH"
        echo "Config:     $VLA_CONFIG_PATH"
        return 1
    fi

    if [ "$mode" = "--dry-run" ]; then
        rsync_args+=(--dry-run)
    fi

    echo "Sync profile: $VLA_PROFILE ($VLA_MODEL_LABEL)"
    echo "Remote root:  $remote_base"
    echo "Checkpoint:   $ckpt_rel"
    echo "Config:       $config_rel"

    if [ "$mode" = "--print-only" ]; then
        echo "rsync ${rsync_args[*]} $VLA_PROJECT_DIR/./$ckpt_rel $VLA_PROJECT_DIR/./$config_rel $remote_base/"
        return 0
    fi

    rsync "${rsync_args[@]}" \
        "$VLA_PROJECT_DIR/./$ckpt_rel" \
        "$VLA_PROJECT_DIR/./$config_rel" \
        "$remote_base/"
}

unalias vla-sync-profile 2>/dev/null || true
vla-sync-profile() {
    vla-sync-models "$@"
}

alias vla-sync='vla-sync-models'

unalias vla-start 2>/dev/null || true
unalias vla-restart 2>/dev/null || true
unalias vla-stop 2>/dev/null || true
unalias vla-status 2>/dev/null || true
unalias vla-logs 2>/dev/null || true
unalias vla-server 2>/dev/null || true
unalias vla-server-running 2>/dev/null || true
unalias vla-api-is-local 2>/dev/null || true
unalias vla-clean 2>/dev/null || true

vla-api-is-local() {
    case "${VLA_API_SERVER:-http://localhost:8000}" in
        http://localhost:*|http://127.0.0.1:*|http://0.0.0.0:*|https://localhost:*|https://127.0.0.1:*)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

vla-server-running() {
    local api_url="${VLA_API_SERVER:-http://127.0.0.1:${VLA_PORT:-8000}}"
    curl -s "${api_url%/}/health" > /dev/null 2>&1
}

vla-server() {
    local action="start"
    case "${1:-start}" in
        start|stop|restart|status|logs|http|admin|urls)
            action="$1"
            if [ "$#" -gt 0 ]; then
                shift
            fi
            ;;
    esac

    local profile_name="${1:-${VLA_PROFILE:-end_to_end_default}}"
    local api_url="${VLA_API_SERVER:-http://127.0.0.1:${VLA_PORT:-8000}}"

    if [ "$action" = "start" ] || [ "$action" = "restart" ] || [ "$action" = "status" ]; then
        eval "$(python3 "$VLA_PROJECT_DIR/scripts/vla_profile.py" env --profile "$profile_name")"
    fi

    if [ "$action" = "http" ] || [ "$action" = "admin" ] || [ "$action" = "urls" ]; then
        echo "MoNaVLA local HTTP management"
        echo "  Root:   ${api_url%/}/"
        echo "  Health: ${api_url%/}/health"
        echo "  Admin:  ${api_url%/}/admin"
        echo "  Docs:   ${api_url%/}/docs"
        if [ "$action" != "urls" ]; then
            if command -v xdg-open >/dev/null 2>&1; then
                xdg-open "${api_url%/}/admin" >/dev/null 2>&1 &
            elif command -v open >/dev/null 2>&1; then
                open "${api_url%/}/admin" >/dev/null 2>&1 &
            fi
        fi
        return 0
    fi

    "$VLA_PROJECT_DIR/scripts/manage_api_server.sh" "$action" "$profile_name"
}

vla-start() { vla-server start "$@"; }
vla-restart() { vla-server restart "$@"; }
vla-stop() { vla-server stop "$@"; }
vla-status() { vla-server status "$@"; }
vla-logs() { vla-server logs "$@"; }

vla-clean() {
    local patterns=(
        "$VLA_PROJECT_DIR/robovlm_nav/serve/inference_server.py"
        "$VLA_PROJECT_DIR/scripts/gradio_inference_dashboard.py"
        "$VLA_PROJECT_DIR/scripts/gradio_data_collector.py"
        "camera_publisher_continuous"
        "camera_service_server"
        "usb_camera_service_server"
        "launch_mobile_vla.launch.py"
    )
    local pattern=""
    echo "Cleaning MoNaVLA runtime processes..."
    for pattern in "${patterns[@]}"; do
        pkill -f "$pattern" 2>/dev/null || true
    done
    sleep 1
    for pattern in "${patterns[@]}"; do
        pkill -9 -f "$pattern" 2>/dev/null || true
    done
    rm -f "$VLA_PROJECT_DIR/logs/api_server.pid"
    echo "✓ Cleaned server / gradio / camera-related processes"
}

unalias vla-inference-gradio 2>/dev/null || true
vla-inference-gradio() {
    local profile_name="${1:-${VLA_PROFILE:-proxy_default}}"
    # profile 로드 실패 시 현재 env 변수 그대로 사용
    eval "$(python3 "$VLA_PROJECT_DIR/scripts/vla_profile.py" env --profile "$profile_name" 2>/dev/null)" || true
    # proxy_server 또는 api_server 런타임이 아니면 env 변수로 fallback
    if [ "$VLA_MODEL_RUNTIME" != "api_server" ] && [ "$VLA_MODEL_RUNTIME" != "proxy_server" ]; then
        if [ -n "$VLA_API_SERVER" ]; then
            echo "⚠️  Profile runtime 미확인, VLA_API_SERVER=$VLA_API_SERVER 로 fallback"
            export VLA_MODEL_RUNTIME="proxy_server"
        else
            echo "⚠️  Profile $VLA_PROFILE uses runtime $VLA_MODEL_RUNTIME — not launchable via gradio."
            echo "    Try: vla-inference-gradio proxy_default  또는  vla-inference-gradio exp49_proxy"
            return 1
        fi
    fi
    if [ -f "/opt/ros/humble/setup.zsh" ]; then
        source /opt/ros/humble/setup.zsh
    elif [ -f "/opt/ros/humble/setup.bash" ]; then
        source /opt/ros/humble/setup.bash
    fi
    if [ -f "$VLA_ROS_WS/install/setup.zsh" ]; then
        source "$VLA_ROS_WS/install/setup.zsh"
    elif [ -f "$VLA_ROS_WS/install/setup.bash" ]; then
        source "$VLA_ROS_WS/install/setup.bash"
    fi

    export VLA_DASHBOARD_BACKEND="API Server"

    if vla-api-is-local; then
        if ! vla-server-running; then
            echo "API server is not running at $VLA_API_SERVER"
            echo "Starting local vla-server with profile $VLA_PROFILE..."
            vla-server start "$profile_name" || return 1
        fi
    else
        echo "Using remote API server: $VLA_API_SERVER"
    fi

    echo "Recommended runtime stack: vla-camera | vla-server | vla-inference-gradio"
    echo "Launching inference dashboard with profile $VLA_PROFILE ($VLA_MODEL_LABEL) in API Server mode"
    python3 "$VLA_PROJECT_DIR/scripts/gradio_inference_dashboard.py"
}

unalias vla-collect-gradio 2>/dev/null || true
vla-collect-gradio() {
    local profile_name="${1:-collect_default}"
    eval "$(python3 "$VLA_PROJECT_DIR/scripts/vla_profile.py" env --profile "$profile_name")"
    if [ -f "/opt/ros/humble/setup.zsh" ]; then
        source /opt/ros/humble/setup.zsh
    elif [ -f "/opt/ros/humble/setup.bash" ]; then
        source /opt/ros/humble/setup.bash
    fi
    if [ -f "$VLA_ROS_WS/install/setup.zsh" ]; then
        source "$VLA_ROS_WS/install/setup.zsh"
    elif [ -f "$VLA_ROS_WS/install/setup.bash" ]; then
        source "$VLA_ROS_WS/install/setup.bash"
    fi
    echo "Launching collector with profile $VLA_PROFILE"
    python3 "$VLA_PROJECT_DIR/scripts/gradio_data_collector.py"
}

# Compatibility aliases
unalias vla-collect 2>/dev/null || true
vla-collect() { vla-collect-gradio "$@"; }
unalias vla-dashboard 2>/dev/null || true
vla-dashboard() { vla-inference-gradio "$@"; }
alias mona-collect-gradio='vla-collect-gradio'
alias mona-inference-gradio='vla-inference-gradio'
alias mona-server='vla-server'
alias mona-clean='vla-clean'
alias mona-profile='vla-profile'
alias mona-models='vla-models'
alias mona-doctor='vla-doctor'
alias mona-sync='vla-sync-models'

alias vla-reset='vla-clean'
